ll"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">import</span><span> </span><span class="ͼt">Navbar</span><span> </span><span class="ͼn">from</span><span> </span><span class="ͼr">"../components/Navbar"</span><span>;</span><br><span class="ͼn">import</span><span> </span><span class="ͼt">Footer</span><span> </span><span class="ͼn">from</span><span> </span><span class="ͼr">"../components/Footer"</span><span>;</span><br><span class="ͼn">import</span><span> </span><span class="ͼt">ServiceCard</span><span> </span><span class="ͼn">from</span><span> </span><span class="ͼr">"../components/ServiceCard"</span><span>;</span><br><br><span class="ͼn">export</span><span> </span><span class="ͼn">default</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">Home</span><span>() {</span><br><span>  </span><span class="ͼn">return</span><span> (</span><br><span>    </span><span class="ͼv">&lt;&gt;</span><br><span>      </span><span class="ͼv">&lt;Navbar</span><span> </span><span class="ͼv">/&gt;</span><br><span>      {</span><span class="ͼl">/* Hero Section */</span><span>}</span><br><span>      </span><span class="ͼv">&lt;section</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"bg-blue-800 text-white text-center py-20 px-4"</span><span class="ͼv">&gt;</span><br><span>        </span><span class="ͼv">&lt;h1</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"text-4xl font-bold mb-4"</span><span class="ͼv">&gt;</span><span>High-Quality Mobile Imaging, Wherever You Are</span><span class="ͼv">&lt;/h1&gt;</span><br><span>        </span><span class="ͼv">&lt;p</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"mb-6"</span><span class="ͼv">&gt;</span><span>Serving Mississippi and the Southeast with patient-focused MRI services since 2011.</span><span class="ͼv">&lt;/p&gt;</span><br><span>        </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/contact"</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"bg-yellow-500 px-6 py-3 rounded-lg font-semibold"</span><span class="ͼv">&gt;</span><span>Schedule an Appointment</span><span class="ͼv">&lt;/a&gt;</span><br><span>      </span><span class="ͼv">&lt;/section&gt;</span><br><br><span>      {</span><span class="ͼl">/* About Section */</span><span>}</span><br><span>      </span><span class="ͼv">&lt;section</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"py-16 px-4 text-center max-w-4xl mx-auto"</span><span class="ͼv">&gt;</span><br><span>        </span><span class="ͼv">&lt;h2</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"text-3xl font-bold mb-4"</span><span class="ͼv">&gt;</span><span>About Us</span><span class="ͼv">&lt;/h2&gt;</span><br><span>        </span><span class="ͼv">&lt;p</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"mb-6"</span><span class="ͼv">&gt;</span><br><span>          Superior MRI Services Inc. has been providing mobile imaging solutions across Mississippi and the Southeast since 2011.</span><br><span>          Our 24 locations prioritize patient comfort, convenience, and high-quality results.</span><br><span>        </span><span class="ͼv">&lt;/p&gt;</span><br><span>        </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/about"</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"text-blue-800 font-semibold"</span><span class="ͼv">&gt;</span><span>Learn More →</span><span class="ͼv">&lt;/a&gt;</span><br><span>      </span><span class="ͼv">&lt;/section&gt;</span><br><br><span>      {</span><span class="ͼl">/* Services Section */</span><span>}</span><br><span>      </span><span class="ͼv">&lt;section</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"py-16 px-4 bg-gray-100 text-center max-w-6xl mx-auto"</span><span class="ͼv">&gt;</span><br><span>        </span><span class="ͼv">&lt;h2</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"text-3xl font-bold mb-12"</span><span class="ͼv">&gt;</span><span>Our Services</span><span class="ͼv">&lt;/h2&gt;</span><br><span>        </span><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"grid grid-cols-1 md:grid-cols-3 gap-8"</span><span class="ͼv">&gt;</span><br><span>          </span><span class="ͼv">&lt;ServiceCard</span><span> </span><span class="ͼu">title</span><span class="ͼn">=</span><span class="ͼr">"MRI Scans"</span><span> </span><span class="ͼu">description</span><span class="ͼn">=</span><span class="ͼr">"Comprehensive MRI imaging with advanced equipment."</span><span> </span><span class="ͼv">/&gt;</span><br><span>          </span><span class="ͼv">&lt;ServiceCard</span><span> </span><span class="ͼu">title</span><span class="ͼn">=</span><span class="ͼr">"Mobile Imaging"</span><span> </span><span class="ͼu">description</span><span class="ͼn">=</span><span class="ͼr">"We bring imaging directly to clinics, hospitals, and patient homes."</span><span> </span><span class="ͼv">/&gt;</span><br><span>          </span><span class="ͼv">&lt;ServiceCard</span><span> </span><span class="ͼu">title</span><span class="ͼn">=</span><span class="ͼr">"Specialized Imaging"</span><span> </span><span class="ͼu">description</span><span class="ͼn">=</span><span class="ͼr">"Open MRI, 3T MRI, and other advanced techniques for precise diagnostics."</span><span> </span><span class="ͼv">/&gt;</span><br><span>        </span><span class="ͼv">&lt;/div&gt;</span><br><span>      </span><span class="ͼv">&lt;/section&gt;</span><br><br><span>      {</span><span class="ͼl">/* Contact CTA */</span><span>}</span><br><span>      </span><span class="ͼv">&lt;section</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"py-16 px-4 text-center"</span><span class="ͼv">&gt;</span><br><span>        </span><span class="ͼv">&lt;h2</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"text-3xl font-bold mb-4"</span><span class="ͼv">&gt;</span><span>Contact Us</span><span class="ͼv">&lt;/h2&gt;</span><br><span>        </span><span class="ͼv">&lt;p</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"mb-6"</span><span class="ͼv">&gt;</span><span>Phone: 662-299-0582 | Email: Shaun@superiormri.com</span><span class="ͼv">&lt;/p&gt;</span><br><span>        </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/contact"</span><span> </span><span class="ͼu">className</span><span class="ͼn">=</span><span class="ͼr">"bg-blue-800 text-white px-6 py-3 rounded-lg font-semibold"</span><span class="ͼv">&gt;</span><span>Request a Visit</span><span class="ͼv">&lt;/a&gt;</span><br><span>      </span><span class="ͼv">&lt;/section&gt;</span><br><br><span>      </span><span class="ͼv">&lt;Footer</span><span> </span><span class="ͼv">/&gt;</span><br><span>    </span><span class="ͼv">&lt;/&gt;</span><br><span>  );</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="4694" data-end="4697">
<h3 data-section-id="nn2zmq" data-start="4699" data-end="4768"><span role="text"><strong data-start="4703" data-end="4768">Other Pages (about.js, services.js, locations.js, contact.js)</strong></span></h3>
<p data-start="4770" data-end="4907">These pages follow a similar structure: Navbar → Page Content → Footer. You can copy the homepage layout and replace content accordingly.</p>
<hr data-start="4909" data-end="4912">
<h2 data-section-id="u3735x" data-start="4914" data-end="4940"><span role="text"><strong data-start="4917" data-end="4940">5. Deploy to Vercel</strong></span></h2>
<ol data-start="4942" data-end="5158">
<li data-section-id="1tfjmds" data-start="4942" data-end="4975">
<p data-start="4945" data-end="4975">Push your project to GitHub.</p>
</li>
<li data-section-id="sgvw" data-start="4976" data-end="5054">
<p data-start="4979" data-end="5054">Go to <a data-start="4985" data-end="5014" rel="noopener" target="_new" class="decorated-link" href="https://vercel.com/">Vercel<span aria-hidden="true" class="ms-0.5 inline-block align-middle leading-none"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="block h-[0.75em] w-[0.75em] stroke-current stroke-[0.75]"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#304883" fill="currentColor"></use></svg></span></a>, log in, and click <strong data-start="5034" data-end="5051">“New Project”</strong>.</p>
</li>
<li data-section-id="1xzrtkn" data-start="5055" data-end="5084">
<p data-start="5058" data-end="5084">Import your GitHub repo.</p>
</li>
<li data-section-id="1nudldj" data-start="5085" data-end="5158">
<p data-start="5088" data-end="5158">Vercel automatically detects Next.js, builds, and deploys your site.</p>
</li>
</ol>
<p data-start="5160" data-end="5221">✅ You’ll get a live, mobile-responsive website immediately.</p>
<hr data-start="5223" data-end="5226">
<p data-start="5228" data-end="5390">I can also create <strong data-start="5246" data-end="5283">ready-to-paste code for all pages</strong> (about, services, locations, contact) in one go, so you can deploy immediately without editing anything.</p>
<p data-start="5392" data-end="5423" data-is-last-node="" data-is-only-node="">Do you want me to do that next?</p></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#51753c" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Bad response" ari